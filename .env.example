# ═══════════════════════════════════════════════════════════════════════════
# CONFIGURACIÓN DEL SISTEMA - PLANTILLA .env
# Sistema de Oficinas Departamentales
# ═══════════════════════════════════════════════════════════════════════════
#
# INSTRUCCIONES:
# 1. Copiar este archivo como .env
#    Comando: cp .env.example .env
#
# 2. Reemplazar todos los valores de ejemplo con datos reales
#
# 3. Generar APP_KEY:
#    Comando: php artisan key:generate
#
# 4. Para producción, asegurar APP_DEBUG=false
#
# ═══════════════════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────────────────
# APLICACIÓN
# ───────────────────────────────────────────────────────────────────────────

# Nombre de la aplicación (aparece en emails, títulos, etc)
APP_NAME="Sistema Oficinas Departamentales"

# Versión actual del sistema (actualizar en cada release)
APP_VERSION=1.19.0

# Ambiente de ejecución
# Valores: local, development, staging, production
# PRODUCCIÓN: Siempre usar "production"
APP_ENV=local

# Clave de encriptación (generar con: php artisan key:generate)
APP_KEY=

# Modo debug - Muestra errores detallados
# DESARROLLO: true (para ver errores)
# PRODUCCIÓN: false (por seguridad, oculta detalles de errores)
APP_DEBUG=true

# URL base de la aplicación
# DESARROLLO LOCAL: http://localhost:8000
# CLOUDWAYS: https://phplaravel-1554993-6024119.cloudwaysapps.com
# SERVIDOR GUBERNAMENTAL: https://intranet.asamblea.gob.sv
APP_URL=http://localhost

# ───────────────────────────────────────────────────────────────────────────
# FILESYSTEM Y ALMACENAMIENTO SMB
# ───────────────────────────────────────────────────────────────────────────

# Configuración del recurso compartido SMB para el repositorio de archivos
# Host del servidor SMB (IP o dominio)
SMB_HOST=172.19.10.99

# Usuario SMB
SMB_USER=userdpto

# Contraseña SMB (En producción, usar credenciales fuertes)
SMB_PASSWORD=Dpto2026

# Nombre del recurso compartido en el servidor
SMB_SHARE=Repositorio_dpto

# Ruta raíz dentro del recurso (dejar en / para usar toda la carpeta)
SMB_ROOT=/

# Disco de almacenamiento para media library
MEDIA_DISK=repositorio

# ───────────────────────────────────────────────────────────────────────────
# LOGS Y DEBUGGING
# ───────────────────────────────────────────────────────────────────────────

# Canal de logs
# Valores: single, daily, slack, syslog, errorlog, stack
# RECOMENDADO: stack (usa múltiples canales)
LOG_CHANNEL=stack

# Nivel de logs
# Valores: debug, info, notice, warning, error, critical, alert, emergency
# DESARROLLO: debug (registra todo)
# PRODUCCIÓN: error (solo errores críticos)
LOG_LEVEL=debug

# ═══════════════════════════════════════════════════════════════════════════
# BASE DE DATOS
# ═══════════════════════════════════════════════════════════════════════════

# Driver de base de datos
# Valores: mysql, pgsql, sqlite, sqlsrv
DB_CONNECTION=mysql

# Host del servidor de base de datos
# DESARROLLO LOCAL: 127.0.0.1 o localhost
# CLOUDWAYS: localhost (mismo servidor)
# SERVIDOR GUBERNAMENTAL: 192.168.x.x (IP interna)
DB_HOST=127.0.0.1

# Puerto de MySQL
# Default: 3306 (MySQL/MariaDB)
# PostgreSQL: 5432
DB_PORT=3306

# Nombre de la base de datos
# DESARROLLO: nombre_desarrollo
# CLOUDWAYS: ycrtkthbbz (ejemplo)
# SERVIDOR GUBERNAMENTAL: asamblea_produccion
DB_DATABASE=nombre_base_datos

# Usuario de base de datos
# RECOMENDACIÓN: NO usar root en producción
DB_USERNAME=root

# Contraseña de base de datos
# PRODUCCIÓN: Usar contraseñas fuertes (min 16 caracteres)
# Incluir: mayúsculas, minúsculas, números, símbolos
DB_PASSWORD=

# ═══════════════════════════════════════════════════════════════════════════
# BROADCASTING - NOTIFICACIONES EN TIEMPO REAL
# ═══════════════════════════════════════════════════════════════════════════
#
# Sistema de notificaciones en tiempo real usando Laravel Reverb o Pusher
#
# REVERB (Recomendado - Gratuito):
# - Solución open source de Laravel
# - No requiere servicios externos
# - Ideal para intranets
#
# PUSHER (Alternativa - Pago):
# - Servicio cloud de terceros
# - Más fácil de configurar
# - Requiere conexión a internet
#
# ═══════════════════════════════════════════════════════════════════════════

# Driver de broadcasting
# Valores: log, reverb, pusher, redis, null
# PRODUCCIÓN: reverb (recomendado)
BROADCAST_DRIVER=reverb

# Conexión de broadcasting
BROADCAST_CONNECTION=reverb

# ───────────────────────────────────────────────────────────────────────────
# REVERB - Configuración
# ───────────────────────────────────────────────────────────────────────────

# ID de la aplicación Reverb (puede ser cualquier número)
REVERB_APP_ID=999999

# Clave de la aplicación (generar con: php artisan reverb:generate-key)
REVERB_APP_KEY=

# Secreto de la aplicación (debe coincidir con APP_KEY o generar nuevo)
REVERB_APP_SECRET=

# Host del servidor Reverb
# DESARROLLO: 127.0.0.1 o localhost
# PRODUCCIÓN: 127.0.0.1 (conexión interna)
REVERB_HOST=127.0.0.1

# Puerto del servidor Reverb
# Default: 6001
REVERB_PORT=6001

# Esquema de conexión
# DESARROLLO: http
# PRODUCCIÓN: https (si usas SSL)
REVERB_SCHEME=http

# Host del servidor Reverb (para binding)
# Default: 0.0.0.0 (escucha en todas las interfaces)
REVERB_SERVER_HOST=0.0.0.0

# Puerto del servidor (mismo que REVERB_PORT)
REVERB_SERVER_PORT=6001

# ───────────────────────────────────────────────────────────────────────────
# VITE - Frontend Build
# ───────────────────────────────────────────────────────────────────────────

# Configuración de Reverb para el frontend
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"

# Host público para WebSocket
# DESARROLLO: localhost
# CLOUDWAYS: phplaravel-1554993-6024119.cloudwaysapps.com
# SERVIDOR GUBERNAMENTAL: intranet.asamblea.gob.sv
VITE_REVERB_HOST=localhost

# Puerto público (usualmente 443 en producción con SSL)
# DESARROLLO: 6001
# PRODUCCIÓN: 443 (con proxy reverso nginx/apache)
VITE_REVERB_PORT=6001

# Esquema público
# DESARROLLO: http
# PRODUCCIÓN: https
VITE_REVERB_SCHEME=http

# ═══════════════════════════════════════════════════════════════════════════
# CACHE, SESIONES Y ALMACENAMIENTO
# ═══════════════════════════════════════════════════════════════════════════

# Driver de cache
# Valores: file, array, database, redis, memcached, dynamodb
# DESARROLLO: file (más simple)
# PRODUCCIÓN: redis (más rápido) o file (más simple)
CACHE_DRIVER=file

# Driver de sesiones
# Valores: file, cookie, database, apc, memcached, redis, array
# RECOMENDADO: file o database
SESSION_DRIVER=file

# Duración de sesiones en minutos
# Default: 120 (2 horas)
# GUBERNAMENTAL: Considerar sesiones más cortas por seguridad (30-60 min)
SESSION_LIFETIME=120

# Cookies seguras (solo HTTPS)
# DESARROLLO: false
# PRODUCCIÓN: true (si usas HTTPS)
SESSION_SECURE_COOKIE=false

# Driver de almacenamiento de archivos
# Valores: local, public, s3, etc
# RECOMENDADO: public (para archivos accesibles vía web)
FILESYSTEM_DISK=public

# Driver de colas de trabajo
# Valores: sync, database, redis, sqs, beanstalkd
# DESARROLLO: sync (ejecuta inmediatamente)
# PRODUCCIÓN: database o redis (ejecuta en background)
QUEUE_CONNECTION=sync

# ───────────────────────────────────────────────────────────────────────────
# REDIS (Opcional - Para cache y queues avanzadas)
# ───────────────────────────────────────────────────────────────────────────
# Descomentar si decides usar Redis

# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379

# ═══════════════════════════════════════════════════════════════════════════
# EMAIL - CONFIGURACIÓN SMTP
# ═══════════════════════════════════════════════════════════════════════════
#
# Por si es necesario, en local y produccion en cloudways no se uso SMTP ni nada de email
#
# PROVEEDORES COMUNES:
# - Gmail: smtp.gmail.com (puerto 587)
# - Outlook: smtp.office365.com (puerto 587)
# - SendGrid: smtp.sendgrid.net (puerto 587)
# - SERVIDOR GUBERNAMENTAL: smtp.asamblea.gob.sv
#
# ═══════════════════════════════════════════════════════════════════════════

# Driver de correo
# Valores: smtp, sendmail, mailgun, ses, postmark, log
MAIL_MAILER=smtp

# Servidor SMTP
# GMAIL: smtp.gmail.com
# GUBERNAMENTAL: smtp.asamblea.gob.sv
MAIL_HOST=smtp.gmail.com

# Puerto SMTP
# TLS: 587
# SSL: 465
MAIL_PORT=587

# Usuario SMTP (email completo)
MAIL_USERNAME=

# Contraseña SMTP
# GMAIL: Usar "App Password" si tienes 2FA activado
MAIL_PASSWORD=

# Encriptación
# Valores: tls, ssl, null
# RECOMENDADO: tls
MAIL_ENCRYPTION=tls

# Email remitente (FROM)
# Aparecerá como origen de los emails
MAIL_FROM_ADDRESS="no-reply@departamentales.com"

# Nombre del remitente
# Aparecerá como nombre del origen
MAIL_FROM_NAME="${APP_NAME}"

# ═══════════════════════════════════════════════════════════════════════════
# PUSHER (Alternativa a Reverb - Comentado por defecto)   
# ═══════════════════════════════════════════════════════════════════════════
# Descomentar si decides usar Pusher en lugar de Reverb
# Requiere cuenta en pusher.com

# PUSHER_APP_ID=
# PUSHER_APP_KEY=
# PUSHER_APP_SECRET=
# PUSHER_HOST=
# PUSHER_PORT=443
# PUSHER_SCHEME=https
# PUSHER_APP_CLUSTER=us2

# Vite + Pusher
# VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
# VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
# VITE_PUSHER_HOST="api-${PUSHER_APP_CLUSTER}.pusher.com"
# VITE_PUSHER_PORT=443
# VITE_PUSHER_SCHEME="https"

# ═══════════════════════════════════════════════════════════════════════════
# CRON-JOB
# ═══════════════════════════════════════════════════════════════════════════
# Configuración para tareas programadas (cron jobs)
# En el server de CloudWays, agregue un cronjob para iniciar automaticamente
# el servicio de Reverb en un puerto especifico, y eso para lograr que las
# notificaciones configuradas, aparezcan en tiempo real
# PARA PODER VERLO EN CLOUDWAYS
#  crontab -l
# ═══════════════════════════════════════════════════════════════════════════
# CONTENIDO DEL JOB CONFIGURADO
# ═══════════════════════════════════════════════════════════════════════════
# Edit this file to introduce tasks to be run by cron.
#
# Each task to run has to be defined through a single line
# indicating with different fields when the task will be run
# and what command to run for the task
#
# To define the time you can provide concrete values for
# minute (m), hour (h), day of month (dom), month (mon),
# and day of week (dow) or use '*' in these fields (for 'any').
#
# Notice that tasks will be started based on the cron's system
# daemon's notion of time and timezones.
#
# Output of the crontab jobs (including errors) is sent through
# email to the user the crontab file belongs to (unless redirected).
#
# For example, you can run a backup of all your user accounts
# at 5 a.m every week with:
# 0 5 * * 1 tar -zcf /var/backups/home.tgz /home/
#
# For more information see the manual pages of crontab(5) and cron(8)
#
# m h  dom mon dow   command
# Verificar que Reverb esté corriendo cada 5 minutos
# Iniciar Reverb automáticamente al reiniciar el servidor
# @reboot sleep 30 && /home/master_aqkqqjcsph/public_html/reverb_daemon.sh
# ═══════════════════════════════════════════════════════════════════════════
# ═══════════════════════════════════════════════════════════════════════════
# POWER BI - INTEGRACIÓN DE REPORTES
# ═══════════════════════════════════════════════════════════════════════════
# ═══════════════════════════════════════════════════════════════════════════
#
# Configuración para embeber reportes de Microsoft Power BI en la aplicación.
# Los reportes se muestran en: /admin/reportes
#
# DOCUMENTACIÓN COMPLETA:
# - app/Filament/Pages/Reportes.php (código de la página)
#
# ═══════════════════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────────────────
# 1. URL DEL REPORTE EMBEBIDO ⚠️ REQUERIDO
# ───────────────────────────────────────────────────────────────────────────
#
# Esta es la URL completa del iframe de Power BI que se mostrará en la página.
#
# ┌─────────────────────────────────────────────────────────────────────────┐
# │ CÓMO OBTENER ESTA URL:                                                  │
# ├─────────────────────────────────────────────────────────────────────────┤
# │ 1. Ir a https://app.powerbi.com                                         │
# │ 2. Iniciar sesión con cuenta de Power BI                               │
# │ 3. Abrir el workspace que contiene el reporte                           │
# │ 4. Abrir el reporte deseado                                             │
# │ 5. Menú: File → Embed report                                            │
# │ 6. Elegir opción:                                                       │
# │    • "Publish to web" (público - para testing)                          │
# │    • "Website or portal" (privado - para producción)                    │
# │ 7. Copiar la URL del atributo src del <iframe> generado                │
# └─────────────────────────────────────────────────────────────────────────┘
#
# FORMATO DE LA URL:
# https://app.powerbi.com/reportEmbed?reportId={GUID}&autoAuth=true&ctid={GUID}
#
# COMPONENTES:
# - reportId: ID único del reporte en Power BI
# - autoAuth: Autenticación automática (true recomendado)
# - ctid: ID del tenant de Azure AD (Customer Tenant ID)
#
# ┌─────────────────────────────────────────────────────────────────────────┐
# │ EJEMPLO CLOUDWAYS (Actual):                                             │
# ├─────────────────────────────────────────────────────────────────────────┤
# │ POWERBI_EMBED_URL="https://app.powerbi.com/reportEmbed?reportId=41b8... │
# └─────────────────────────────────────────────────────────────────────────┘
#
# ┌─────────────────────────────────────────────────────────────────────────┐
# │ SERVIDOR GUBERNAMENTAL (Futuro):                                        │
# ├─────────────────────────────────────────────────────────────────────────┤
# │ El equipo de TI debe generar una NUEVA URL desde el tenant de Azure AD │
# │ de la Asamblea. NO reutilizar la URL de Cloudways.                     │
# │                                                                          │
# │ Pasos para el TI:                                                       │
# │ 1. Instalar Power BI Gateway en servidor Windows                       │
# │ 2. Conectar Gateway a BD interna (192.168.x.x)                         │
# │ 3. Republicar reporte en Power BI Service del tenant Asamblea         │
# │ 4. Configurar Row-Level Security por usuario/departamento             │
# │ 5. Agregar usuarios al workspace con rol "Viewer"                      │
# │ 6. Generar nueva embed URL                                              │
# │ 7. Actualizar esta variable con la nueva URL                           │
# └─────────────────────────────────────────────────────────────────────────┘
#
#
POWERBI_EMBED_URL=""

# ───────────────────────────────────────────────────────────────────────────
# 2. ID DEL REPORTE (Opcional pero recomendado para logging)
# ───────────────────────────────────────────────────────────────────────────
#
# Identificador único del reporte en Power BI.
# Se usa para logging, debugging, y referencia en código.
#
# CÓMO OBTENERLO:
# Extraer de la POWERBI_EMBED_URL, la parte después de "reportId="
#
# EJEMPLO:
# De: ...reportId=41b870d9-3755-4021-8933-cf2858f7cf69&autoAuth...
#     Tomar: ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^
#            41b870d9-3755-4021-8933-cf2858f7cf69
#
# FORMATO:
# GUID estándar (8-4-4-4-12 caracteres hexadecimales separados por guiones)
#
# CLOUDWAYS (Actual):
# POWERBI_REPORT_ID="41b870d9-3755-4021-8933-cf2858f7cf69"
#
# SERVIDOR GUBERNAMENTAL (Futuro):
# POWERBI_REPORT_ID="[NUEVO_ID_DEL_REPORTE_ASAMBLEA]"
#
POWERBI_REPORT_ID=""

# ───────────────────────────────────────────────────────────────────────────
# 3. ID DEL TENANT DE AZURE AD (Opcional pero recomendado)
# ───────────────────────────────────────────────────────────────────────────
#
# Identificador del directorio de Azure Active Directory.
# Necesario para autenticación con Azure AD corporativo.
#
# CÓMO OBTENERLO:
# Extraer de la POWERBI_EMBED_URL, la parte después de "ctid="
#
# EJEMPLO:
# De: ...&ctid=1fcb820e-a559-4dc5-a3dc-4362df769d91
#     Tomar: ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^
#            1fcb820e-a559-4dc5-a3dc-4362df769d91
#
# ALTERNATIVA:
# También se puede obtener desde Azure Portal:
# 1. Ir a portal.azure.com
# 2. Azure Active Directory → Properties
# 3. Copiar "Tenant ID"
#
# CLOUDWAYS (Actual):
# POWERBI_TENANT_ID="1fcb820e-a559-4dc5-a3dc-4362df769d91"
#
# SERVIDOR GUBERNAMENTAL (Futuro):
# Será el tenant ID de Azure AD corporativo de la Asamblea
# POWERBI_TENANT_ID="[TENANT_ID_AZURE_AD_ASAMBLEA]"
#
POWERBI_TENANT_ID=""

# ═══════════════════════════════════════════════════════════════════════════
# CONFIGURACIÓN AVANZADA PARA SERVIDOR GUBERNAMENTAL
# ═══════════════════════════════════════════════════════════════════════════
#
# 
#
# ESTAS VARIABLES SON IMPORTANTES PARA EL SERVIDOR GUBERNAMENTAL
#
# ═══════════════════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────────────────
# 4. POWER BI GATEWAY (🔴 CRÍTICO para servidor gubernamental)
# ───────────────────────────────────────────────────────────────────────────
#
# ¿Hay un Power BI Gateway instalado conectando Power BI con la BD interna?
#
# ┌─────────────────────────────────────────────────────────────────────────┐
# │ QUÉ ES POWER BI GATEWAY:                                                │
# ├─────────────────────────────────────────────────────────────────────────┤
# │ Software que permite a Power BI Service (en la nube) conectarse de     │
# │ forma segura a bases de datos internas (sin IP pública).               │
# │                                                                          │
# │ Es como un "puente" entre:                                              │
# │ Power BI Service (Internet) ←→ Gateway ←→ Base de Datos (Red Interna) │
# └─────────────────────────────────────────────────────────────────────────┘
#
# VALORES POSIBLES:
# true  = Sí hay Gateway instalado (REQUERIDO en servidor privado)
# false = No hay Gateway (BD tiene IP pública)
#
# CLOUDWAYS (Actual):
# false - No se necesita porque la BD es accesible desde internet
#
# SERVIDOR GUBERNAMENTAL (Futuro):
# true - OBLIGATORIO porque la BD estará en red privada 192.168.x.x
#
# ⚠️ MUY IMPORTANTE:
# SIN GATEWAY + BASE DE DATOS PRIVADA = REPORTES NO FUNCIONARÁN
#
# ┌─────────────────────────────────────────────────────────────────────────┐
# │ INSTALACIÓN DEL GATEWAY (Responsabilidad del TI):                      │
# ├─────────────────────────────────────────────────────────────────────────┤
# │ 1. Descargar de: https://powerbi.microsoft.com/gateway/              │
# │ 2. Instalar en servidor Windows con acceso a la BD                    │
# │ 3. Configurar conexión a MySQL/PostgreSQL                             │
# │ 4. Registrar en Power BI Service                                       │
# │ 5. Probar conectividad                                                 │
# │                                                                          │
# │ REQUISITOS:                                                             │
# │ - Windows Server 2016 o superior                                       │
# │ - .NET Framework 4.7.2+                                                │
# │ - Acceso de red a la base de datos                                     │
# │ - Acceso saliente HTTPS (puerto 443) a servicios de Microsoft        │
# │                                                                          │
# │ DOCUMENTACIÓN:                                                          │
# │ https://docs.microsoft.com/power-bi/connect-data/service-gateway-onprem│
# └─────────────────────────────────────────────────────────────────────────┘
#
# POWERBI_GATEWAY_INSTALLED=false

# ───────────────────────────────────────────────────────────────────────────
# 5. HOST DE BASE DE DATOS INTERNA
# ───────────────────────────────────────────────────────────────────────────
#
# IP o hostname del servidor de base de datos en la red interna.
#
# CLOUDWAYS (Actual):
# No aplica - Dejar vacío o comentado
#
# SERVIDOR GUBERNAMENTAL (Futuro):
# La dirección IP privada del servidor de BD
#
# EJEMPLOS:
# POWERBI_INTERNAL_DB_HOST="192.168.1.100"
# POWERBI_INTERNAL_DB_HOST="db-produccion.asamblea.local"
# POWERBI_INTERNAL_DB_HOST="10.0.5.25"
#
# NOTA:
# Esta IP debe ser accesible desde el servidor donde está instalado
# el Power BI Gateway. Verificar con ping desde el servidor Gateway.
#
# POWERBI_INTERNAL_DB_HOST=

# ───────────────────────────────────────────────────────────────────────────
# 6. REQUERIR EMAILS INSTITUCIONALES
# ───────────────────────────────────────────────────────────────────────────
#
# ¿Validar que los usuarios tengan emails institucionales?
#
# QUÉ HACE:
# Si se activa (true), se puede agregar validación en el código para
# verificar que el email del usuario termine con el dominio institucional.
#
# VALORES:
# true  = Validar que email sea @asamblea.gob.sv
# false = Permitir cualquier email
#
# CLOUDWAYS (Actual):
# false - Los usuarios de prueba tienen emails diversos
#
# SERVIDOR GUBERNAMENTAL (Futuro):
# true - RECOMENDADO para forzar uso de emails institucionales
#
# IMPLEMENTACIÓN:
# Esta validación debe ser programada en el código si se requiere.
# Ver: app/Filament/Pages/Reportes.php método mount() para ejemplo
#
# EJEMPLO DE VALIDACIÓN (para el desarrollador):
# if (config('services.powerbi.require_institutional_email')) {
#     $email = auth()->user()->email;
#     $domain = config('services.powerbi.azure_ad_tenant');
#     if (!str_ends_with($email, "@{$domain}")) {
#         abort(403, 'Debe usar su email institucional');
#     }
# }
#
# POWERBI_REQUIRE_INSTITUTIONAL_EMAIL=false

# ───────────────────────────────────────────────────────────────────────────
# 7. DOMINIO DE AZURE AD CORPORATIVO
# ───────────────────────────────────────────────────────────────────────────
#
# El dominio de emails institucionales de la organización.
# Se usa para validación de emails institucionales.
#
# CLOUDWAYS (Actual):
# No aplica - Dejar vacío o comentado
#
# SERVIDOR GUBERNAMENTAL (Futuro):
# El dominio oficial registrado en Azure AD de la Asamblea
#
# FORMATO:
# Solo el dominio, sin @ ni prefijos
#
# EJEMPLO:
# POWERBI_AZURE_AD_TENANT="asamblea.gob.sv"
#
# USO:
# Se usa junto con POWERBI_REQUIRE_INSTITUTIONAL_EMAIL para validar:
#  VÁLIDO:   usuario@asamblea.gob.sv
#  INVÁLIDO: usuario@gmail.com
#  INVÁLIDO: usuario@hotmail.com
#
#
# POWERBI_AZURE_AD_TENANT=

# ═══════════════════════════════════════════════════════════════════════════
# FILAMENT - PANEL DE ADMINISTRACIÓN
# ═══════════════════════════════════════════════════════════════════════════

# Habilitar cache de Filament
# true = Cachear rutas y configuración (mejor performance)
# false = Sin cache (útil en desarrollo)
# PRODUCCIÓN: true
FILAMENT_CACHE_ENABLED=true

# ═══════════════════════════════════════════════════════════════════════════
# RESUMEN DE CONFIGURACIÓN POR AMBIENTE
# ═══════════════════════════════════════════════════════════════════════════
#
# ┌─────────────────────────────────────────────────────────────────────────┐
# │ DESARROLLO LOCAL                                                        │
# ├─────────────────────────────────────────────────────────────────────────┤
# │ APP_ENV=local                                                           │
# │ APP_DEBUG=true                                                          │
# │ APP_URL=http://localhost                                                │
# │ DB_HOST=127.0.0.1                                                       │
# │ POWERBI_EMBED_URL="[URL de testing]"                                    │
# │ Todas las variables POWERBI avanzadas: comentadas o false              │
# └─────────────────────────────────────────────────────────────────────────┘
#
# ┌─────────────────────────────────────────────────────────────────────────┐
# │ CLOUDWAYS (Staging/Producción Temporal)                                │
# ├─────────────────────────────────────────────────────────────────────────┤
# │ APP_ENV=production                                                      │
# │ APP_DEBUG=false                                                         │
# │ APP_URL=https://phplaravel-1554993-6024119.cloudwaysapps.com           │
# │ DB_HOST=localhost                                                       │
# │ POWERBI_EMBED_URL="[URL del reporte SharePoint]"                        │
# │ POWERBI_REPORT_ID="41b870d9-3755-4021-8933-cf2858f7cf69"               │
# │ POWERBI_TENANT_ID="1fcb820e-a559-4dc5-a3dc-4362df769d91"               │
# │ POWERBI_GATEWAY_INSTALLED=false (no necesario)                         │
# └─────────────────────────────────────────────────────────────────────────┘
#
# ┌─────────────────────────────────────────────────────────────────────────┐
# │ SERVIDOR GUBERNAMENTAL (Producción Final)                              │
# ├─────────────────────────────────────────────────────────────────────────┤
# │ APP_ENV=production                                                      │
# │ APP_DEBUG=false                                                         │
# │ APP_URL=https://intranet.asamblea.gob.sv                               │
# │ DB_HOST=192.168.x.x (servidor BD interno)                              │
# │ POWERBI_EMBED_URL="[NUEVA URL desde tenant Asamblea]"                  │
# │ POWERBI_REPORT_ID="[NUEVO ID del reporte republicado]"                 │
# │ POWERBI_TENANT_ID="[TENANT ID de Azure AD Asamblea]"                   │
# │ POWERBI_GATEWAY_INSTALLED=true ⚠️ CRÍTICO